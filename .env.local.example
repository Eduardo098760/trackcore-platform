# Traccar API Configuration
# Copie este arquivo para .env.local e ajuste conforme necessário

# URL do servidor Traccar (padrão: localhost:8082)
NEXT_PUBLIC_API_URL=http://localhost:8082/api

# Para produção, altere para:
# NEXT_PUBLIC_API_URL=https://seu-servidor-traccar.com/api

# ===== TENANT DEFAULT =====
# Define qual tenant será usado como fallback quando o hostname não é reconhecido
NEXT_PUBLIC_DEFAULT_TENANT=sv03.rastrear.app.br
